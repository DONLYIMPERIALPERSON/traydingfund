generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  fullName           String?
  nickName           String?
  role               String    @default("trader")
  status             String    @default("active")
  kycStatus          String?   @default("pending")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  challengeAccounts  ChallengeAccount[]
  cTraderAccounts    CTraderAccount[]
  orders             Order[]
  payouts            Payout[]
}

model ChallengeAccount {
  id              Int      @id @default(autoincrement())
  challengeId     String   @unique
  accountSize     String
  phase           String
  objectiveStatus String
  isActive        Boolean  @default(true)
  mt5Account      String?
  startedAt       DateTime?
  breachedAt      DateTime?
  passedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model CTraderAccount {
  id            Int      @id @default(autoincrement())
  challengeId   String   @unique
  accountSize   String
  phase         String
  status        String
  brokerName    String
  accountNumber String
  assignedAt    DateTime?
  startedAt     DateTime?
  breachedAt    DateTime?
  passedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  metrics       CTraderAccountMetric?
}

model CTraderAccountMetric {
  id                     Int      @id @default(autoincrement())
  balance                Float
  equity                 Float
  unrealizedPnl           Float
  maxPermittedLossLeft    Float
  highestBalance          Float
  breachBalance           Float
  profitTargetBalance     Float
  winRate                 Float
  closedTradesCount       Int
  winningTradesCount      Int
  lotsTradedTotal          Float
  todayClosedPnl          Float
  todayTradesCount        Int
  todayLotsTotal          Float
  minTradingDaysRequired  Int
  minTradingDaysMet       Boolean
  stageElapsedHours       Float
  scalpingViolationsCount Int
  capturedAt              DateTime @default(now())

  accountId               Int      @unique
  account                 CTraderAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Order {
  id              Int      @id @default(autoincrement())
  providerOrderId String   @unique
  status          String
  assignmentStatus String
  currency        String
  grossAmountKobo Int
  discountAmountKobo Int
  netAmountKobo   Int
  planId          String
  accountSize     String
  couponCode      String?
  checkoutUrl     String?
  paymentMethod   String
  paymentProvider String
  cryptoCurrency  String?
  cryptoAddress   String?
  safehavenAccountId String?
  safehavenAccountNumber String?
  safehavenAccountName String?
  safehavenBankName String?
  safehavenExpiresAt DateTime?
  safehavenSessionId String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model Payout {
  id               Int      @id @default(autoincrement())
  amountKobo       Int
  status           String
  requestedAt      DateTime @default(now())
  completedAt      DateTime?
  reference        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId           Int
  user             User     @relation(fields: [userId], references: [id])
}

model AdminAllowlist {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  fullName     String?
  role         String   @default("admin")
  status       String   @default("active")
  allowedPages String[]
  requireMfa   Boolean  @default(false)
  canAssignMt5 Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TradingObjectiveConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  rules     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}