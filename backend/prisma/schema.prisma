generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  fullName           String?
  nickName           String?
  useNicknameForCertificates Boolean @default(false)
  role               String    @default("trader")
  status             String    @default("active")
  kycStatus          String?   @default("pending")
  payoutMethodType   String?
  payoutBankName     String?
  payoutBankCode     String?
  payoutAccountNumber String?
  payoutAccountName  String?
  payoutCryptoCurrency String?
  payoutCryptoAddress String?
  payoutCryptoFirstName String?
  payoutCryptoLastName  String?
  payoutSafeHavenReference String?
  payoutSafeHavenPayload Json?
  payoutVerifiedAt   DateTime?
  payoutUpdatedAt    DateTime?
  overallRewardCurrency String @default("USD")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  challengeAccounts  ChallengeAccount[]
  cTraderAccounts    CTraderAccount[]
  orders             Order[]
  payouts            Payout[]
  kycRequests        KycRequest[]
  affiliateOrders    Order[]   @relation("AffiliateOrders")
  affiliateCommissions AffiliateCommission[] @relation("AffiliateCommissions")
  affiliatePayouts   AffiliatePayout[] @relation("AffiliatePayouts")
  certificates       Certificate[]
  emailLogs          EmailLog[]
  supportTickets     SupportTicket[]
  couponRedemptions  CouponRedemption[]
  challengePlans     ChallengePlan[]
  accountRecoveryRequests AccountRecoveryRequest[]
}

model ChallengePlan {
  id                 Int      @id @default(autoincrement())
  planId             String   @unique
  name               String
  accountSize        String
  price              Float
  currency           String   @default("USD")
  maxDrawdown        String?
  profitTarget       String?
  phases             String?
  minTradingDays     String?
  profitSplit        String?
  profitCap          String?
  payoutFrequency    String?
  status             String   @default("Available")
  enabled            Boolean  @default(true)
  challengeType      String?
  phase              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  createdByUserId    Int?
  createdBy          User?    @relation(fields: [createdByUserId], references: [id])

  @@index([enabled])
  @@index([status])
}

model Coupon {
  id              Int      @id @default(autoincrement())
  code            String   @unique
  discountType    String
  discountValue   Float
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  maxUses         Int?
  usedCount       Int      @default(0)
  appliesToAllPlans Boolean @default(true)
  applicablePlanIds String[]
  appliesToAllChallengeTypes Boolean @default(true)
  applicableChallengeTypes  String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  redemptions     CouponRedemption[]

  @@index([isActive])
  @@index([expiresAt])
}

model CouponRedemption {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now())

  couponId   Int
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
}

model SupportTicket {
  id             Int       @id @default(autoincrement())
  subject        String
  status         String    @default("open")
  priority       String    @default("low")
  assignedTo     String?
  lastMessage    String?
  userUnreadCount Int      @default(0)
  adminUnreadCount Int     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  messages       SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
}

model SupportMessage {
  id         Int      @id @default(autoincrement())
  sender     String
  message    String?
  imageUrl   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticketId   Int
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model ChallengeAccount {
  id              Int      @id @default(autoincrement())
  challengeId     String   @unique
  accountSize     String
  phase           String
  objectiveStatus String
  isActive        Boolean  @default(true)
  mt5Account      String?
  startedAt       DateTime?
  breachedAt      DateTime?
  passedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model CTraderAccount {
  id            Int      @id @default(autoincrement())
  challengeId   String   @unique
  platform      String   @default("ctrader")
  accountSize   String
  currency      String   @default("USD")
  phase         String
  challengeType String?
  initialBalance Float?
  maxDdPercent  Float?
  maxDdAmount   Float?
  dailyDdPercent Float?
  dailyDdAmount Float?
  profitTargetPercent Float?
  profitTargetAmount Float?
  minTradingDaysRequired Int?
  minTradeDurationMinutes Int?
  profitSplitPercent Float?
  withdrawalSchedule String?
  status        String
  accessStatus  String?  @default("pending")
  brokerName    String
  accountNumber String
  mt5Login      String?
  mt5Server     String?
  mt5Password   String?
  assignedAt    DateTime?
  accessGrantedAt DateTime?
  startedAt     DateTime?
  breachedAt    DateTime?
  passedAt      DateTime?
  lastRefreshRequestedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([platform, status, accountSize, currency])

  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  metrics       CTraderAccountMetric?
  payouts       Payout[]
  adjustments   AccountAdjustment[]
  emailLogs     EmailLog[]
  recoveryRequests AccountRecoveryRequest[]
}

model CTraderAccountMetric {
  id                     Int      @id @default(autoincrement())
  balance                Float
  equity                 Float
  unrealizedPnl           Float
  maxPermittedLossLeft    Float
  highestBalance          Float
  breachBalance           Float
  profitTargetBalance     Float
  winRate                 Float
  closedTradesCount       Int
  winningTradesCount      Int
  lotsTradedTotal          Float
  todayClosedPnl          Float
  todayTradesCount        Int
  todayLotsTotal          Float
  minTradingDaysRequired  Int
  minTradingDaysMet       Boolean
  stageElapsedHours       Float
  scalpingViolationsCount Int
  durationViolationsCount Int      @default(0)
  processedTradeIds       String[] @default([])
  dailyStartAt            DateTime?
  dailyHighBalance        Float     @default(0)
  dailyBreachBalance       Float     @default(0)
  dailyLowEquity          Float?
  drawdownPercent         Float?
  dailyDrawdownPercent    Float?
  firstTradeAt            DateTime?
  totalTrades             Int       @default(0)
  tradingDaysCount        Int?
  tradingCycleStart       DateTime?
  tradingCycleSource      String?
  shortDurationViolation  Boolean   @default(false)
  breachReason            String?
  minEquity               Float?
  minEquityNote           String?
  engineId                String?
  latencyMs               Float?
  lastBalance             Float     @default(0)
  lastEquity              Float     @default(0)
  expectedBalanceChange   Boolean   @default(false)
  expectedChangeExpiresAt DateTime?
  expectedBalanceOperationType String?
  expectedBalanceOperationExpiresAt DateTime?
  expectedBalanceOperationAmount Float?
  breachEvent            Json?
  tradeDurationViolations Json?
  capturedAt              DateTime @default(now())

  accountId               Int      @unique
  account                 CTraderAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model AccountAdjustment {
  id         Int      @id @default(autoincrement())
  type       String
  amount     Float
  reason     String?
  createdAt  DateTime @default(now())

  accountId  Int
  account    CTraderAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Order {
  id              Int      @id @default(autoincrement())
  providerOrderId String   @unique
  idempotencyKey  String?
  status          String
  assignmentStatus String
  currency        String
  grossAmountKobo Int
  discountAmountKobo Int
  netAmountKobo   Int
  planId          String
  accountSize     String
  challengeType   String?
  phase           String?
  couponCode      String?
  checkoutUrl     String?
  paymentMethod   String
  paymentProvider String
  cryptoCurrency  String?
  cryptoAddress   String?
  safehavenAccountId String?
  safehavenAccountNumber String?
  safehavenAccountName String?
  safehavenBankName String?
  safehavenExpiresAt DateTime?
  safehavenSessionId String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  paidAt          DateTime?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  affiliateId     Int?
  affiliate       User?    @relation("AffiliateOrders", fields: [affiliateId], references: [id])
  affiliateCommission AffiliateCommission?

  @@index([userId])
  @@index([idempotencyKey])
}

model AffiliateCommission {
  id         Int      @id @default(autoincrement())
  amountKobo Int
  status     String   @default("earned")
  createdAt  DateTime @default(now())
  paidAt     DateTime?

  orderId    Int   @unique
  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  affiliateId Int
  affiliate  User @relation("AffiliateCommissions", fields: [affiliateId], references: [id])
}

model AffiliatePayout {
  id                  Int      @id @default(autoincrement())
  amountKobo          Int
  status              String   @default("pending")
  payoutMethodType    String?
  payoutBankName      String?
  payoutBankCode      String?
  payoutAccountNumber String?
  payoutAccountName   String?
  payoutCryptoCurrency String?
  payoutCryptoAddress  String?
  payoutCryptoFirstName String?
  payoutCryptoLastName  String?
  requestedAt         DateTime @default(now())
  approvedAt          DateTime?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  affiliateId         Int
  affiliate           User     @relation("AffiliatePayouts", fields: [affiliateId], references: [id])
}

model Payout {
  id               Int      @id @default(autoincrement())
  providerRef      String?  @unique
  idempotencyKey   String?
  amountKobo       Int
  profitSplitPercent Float?
  profitBaseAmount Float?
  profitAmount     Float?
  payoutMethodType String?
  payoutBankName   String?
  payoutBankCode   String?
  payoutAccountNumber String?
  payoutAccountName String?
  payoutCryptoCurrency String?
  payoutCryptoAddress String?
  payoutCryptoFirstName String?
  payoutCryptoLastName String?
  status           String
  requestedAt      DateTime @default(now())
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectionReason  String?
  metadata         Json?
  completedAt      DateTime?
  reference        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId           Int
  user             User     @relation(fields: [userId], references: [id])
  accountId        Int?
  account          CTraderAccount? @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([accountId])
  @@index([idempotencyKey])
}

model AdminAllowlist {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  fullName     String?
  role         String   @default("admin")
  status       String   @default("active")
  allowedPages String[]
  requireMfa   Boolean  @default(false)
  canAssignMt5 Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TradingObjectiveConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  rules     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KycRequest {
  id              Int      @id @default(autoincrement())
  status          String   @default("pending")
  documentType    String
  documentNumber  String
  idFrontUrl      String
  idBackUrl       String?
  selfieUrl       String?
  submittedAt     DateTime @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  declineReason   String?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model Certificate {
  id                Int      @id @default(autoincrement())
  type              String
  title             String
  description       String?
  certificateUrl    String
  generatedAt       DateTime @default(now())
  relatedEntityId   String?
  metadata          Json?

  userId            Int
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

model EmailLog {
  id        Int      @id @default(autoincrement())
  accountId Int?
  userId    Int?
  type      String
  metadata  Json?
  sentAt    DateTime @default(now())

  account   CTraderAccount? @relation(fields: [accountId], references: [id])
  user      User?           @relation(fields: [userId], references: [id])

  @@index([accountId])
  @@index([userId])
  @@index([type])
}

model AccountRecoveryRequest {
  id                Int      @id @default(autoincrement())
  email             String
  accountNumber     String
  platform          String   @default("ctrader")
  brokerName        String?
  mt5Login          String?
  mt5Server         String?
  mt5Password       String?
  phase             String
  accountType       String
  accountSize       String
  status            String   @default("pending")
  reviewNote        String?
  declineReason     String?
  submittedAt       DateTime @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  recoveredAccountId Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  userId            Int

  recoveredAccount  CTraderAccount? @relation(fields: [recoveredAccountId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([accountNumber])
}