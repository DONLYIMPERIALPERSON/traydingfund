# Node dependencies (NEVER commit)
**/node_modules/

# Build outputs (don’t commit)
**/dist/
**/build/
**/.next/
**/.nuxt/
**/.output/
**/out/
**/coverage/
**/.cache/

# Env secrets (don’t commit)
**/.env
*/.env.
!**/.env.example

# Python (if any)
**/_pycache_/
*.pyc
.venv/
env/

# Backend uploads / runtime (common)
**/uploads/
**/tmp/
**/storage/

