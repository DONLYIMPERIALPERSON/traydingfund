{
  "name": "ctrader-ticks",
  "version": "1.0.0",
  "private": true,
  "description": "cTrader Open API tick collector (WebSocket + protobuf) that writes daily JSONL ticks",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "protobufjs": "^7.2.5",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
