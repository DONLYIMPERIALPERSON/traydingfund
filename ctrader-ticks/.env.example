CTRADER_WS_URL=wss://demo.ctraderapi.com:5035
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=

# Comma separated supported symbols to subscribe (defaults to backend supported list)
CTRADER_SYMBOLS=EURUSD,GBPUSD,AUDUSD,NZDUSD,USDJPY,USDCAD,USDCHF,EURGBP,EURJPY,GBPJPY,AUDJPY,NZDJPY,EURCHF,GBPCHF,CADJPY,CHFJPY,EURAUD,XAUUSD,XAGUSD,XPTUSD,US30,US500,USTEC,UK100,DE30,FRA40,JP225,BTCUSD,ETHUSD,USOIL,UKOIL

# Output base dir for tick files
CTRADER_TICKS_DIR=./ticks

# Heartbeat + reconnect
CTRADER_PING_INTERVAL_MS=20000
CTRADER_RECONNECT_DELAY_MS=4000
