NODE_ENV=development

# Backend API
BACKEND_BASE_URL=http://localhost:4000
BACKEND_METRICS_PATH=/api/v1/ctrader/metrics
BACKEND_ACTIVE_ACCOUNTS_PATH=/api/v1/ctrader/active-accounts
BACKEND_ENGINE_SECRET=replace_with_engine_secret

# cTrader Open API
CTRADER_CLIENT_ID=your_client_id
CTRADER_CLIENT_SECRET=your_client_secret
CTRADER_WS_URL=wss://demo.ctraderapi.com:5035
CTRADER_ACCESS_TOKEN=your_access_token
CTRADER_ACCOUNT_IDS=12345,67890

# Scheduler
POLL_INTERVAL_SECONDS=30
ACTIVE_ACCOUNTS_POLL_SECONDS=10